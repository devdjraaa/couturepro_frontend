{
  "appId": "com.couturepro.admin",
  "appName": "Gextimo Admin",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "gextimoapi.novafriq.africa",
      "*.fedapay.com",
      "fedapay.com",
      "*.ngrok-free.app",
      "*.ngrok.io",
      "*.ngrok.app"
    ]
  },
  "android": {
    "adjustMarginsForEdgeToEdge": "disable"
  },
  "plugins": {
    "Network": {},
    "Preferences": {},
    "SystemBars": {
      "insetsHandling": "disable"
    },
    "CapacitorUpdater": {
      "autoUpdate": true,
      "directUpdate": true,
      "updateUrl": "https://gextimoapi.novafriq.africa/api/app/updates",
      "autoDeleteFailed": true,
      "autoDeletePrevious": true
    }
  }
}