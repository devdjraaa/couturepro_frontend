{
  "appId": "com.couturepro.app",
  "appName": "Gextimo",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "gextimoapi.novafriq.africa",
      "*.fedapay.com",
      "fedapay.com"
    ]
  },
  "android": {
    "adjustMarginsForEdgeToEdge": "disable"
  },
  "plugins": {
    "Network": {},
    "Preferences": {},
    "SystemBars": {
      "insetsHandling": "disable"
    },
    "CapacitorUpdater": {
      "autoUpdate": "atBackground",
      "updateUrl": "https://gextimoapi.novafriq.africa/api/app/updates",
      "statsUrl": "",
      "autoDeleteFailed": true,
      "autoDeletePrevious": true
    }
  }
}
