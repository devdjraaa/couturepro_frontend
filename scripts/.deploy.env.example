# Overrides LOCAUX optionnels pour scripts/release.sh (copie en scripts/.deploy.env, gitignoré).
# Aucun secret nécessaire : le déploiement VPS passe par un sudo NOPASSWD
# (/usr/local/sbin/gextimo-deploy). Ce fichier ne sert qu'à des overrides.
#
# Nom d'hôte SSH du VPS (défaut : novafriq)
# GEXTIMO_VPS='novafriq'
