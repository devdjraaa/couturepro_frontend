# ─────────────────────────────────────────────────────────────────────────────
# DÉVELOPPEMENT LOCAL — copier ce fichier en .env.local
#   cp .env.local.example .env.local
#
# .env.local est ignoré par git (*.local dans .gitignore)
# Il surcharge .env sans le modifier → Railway n'est PAS affecté
# ─────────────────────────────────────────────────────────────────────────────

# Backend local (php artisan serve)
VITE_API_BASE_URL=http://localhost:8000/api

# Si tu utilises ngrok pour exposer le backend local sur mobile
# VITE_API_BASE_URL=https://xxxx-xxx-xxx.ngrok-free.app/api
